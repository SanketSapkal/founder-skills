#!/usr/bin/env bash
set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"
SKILLS_DIR="$SCRIPT_DIR/skills"

# Detect npx context: npm sets npm_config_cache in the environment for all npm operations
NPX_MODE=false
[ -n "${npm_config_cache:-}" ] && NPX_MODE=true

# ──────────────────────────────────────────────────────────────
# Platform detection
# ──────────────────────────────────────────────────────────────

detect_platforms() {
  PLATFORMS=()
  command -v claude >/dev/null 2>&1 && PLATFORMS+=("claude")
  command -v codex >/dev/null 2>&1 && PLATFORMS+=("codex")
  command -v cursor >/dev/null 2>&1 && PLATFORMS+=("cursor")
  command -v kiro-cli >/dev/null 2>&1 || command -v kiro >/dev/null 2>&1 && PLATFORMS+=("kiro")
  command -v opencode >/dev/null 2>&1 && PLATFORMS+=("opencode")
  [ -d "$HOME/.windsurf" ] || command -v windsurf >/dev/null 2>&1 && PLATFORMS+=("windsurf")
}

# ──────────────────────────────────────────────────────────────
# Helpers
# ──────────────────────────────────────────────────────────────

strip_frontmatter() {
  # Remove YAML frontmatter (--- to ---) from a SKILL.md, output body only
  local file="$1"
  awk 'BEGIN{skip=0; found=0} /^---$/{if(!found){found=1;skip=1;next} else {skip=0;next}} !skip{print}' "$file"
}

skill_to_markdown() {
  # Convert a SKILL.md to plain markdown: strip frontmatter, keep body
  local file="$1"
  local name
  name=$(grep '^name:' "$file" 2>/dev/null | head -1 | sed 's/^name: *//')
  echo "## /$name"
  echo ""
  strip_frontmatter "$file"
  echo ""
  echo "---"
  echo ""
}

# ──────────────────────────────────────────────────────────────
# Claude Code (native — symlink SKILL.md directories)
# ──────────────────────────────────────────────────────────────

install_claude() {
  local scope="$1" # global or local
  local target_dir

  if [ "$scope" = "global" ]; then
    target_dir="$HOME/.claude/skills"
  else
    target_dir="./.claude/skills"
  fi

  mkdir -p "$target_dir"
  local count=0

  for skill_dir in "$SKILLS_DIR"/*/; do
    local skill_name
    skill_name="$(basename "$skill_dir")"
    local target="$target_dir/$skill_name"

    if [ -L "$target" ]; then
      rm "$target"
    elif [ -d "$target" ]; then
      echo "  Skipping $skill_name — directory exists (not a symlink)"
      continue
    fi

    # npx installs from the npm cache — symlinks to cache paths break when cache is cleared
    if [ "$NPX_MODE" = "true" ]; then
      cp -r "$skill_dir" "$target"
    else
      ln -s "$skill_dir" "$target"
    fi
    count=$((count + 1))
  done

  echo "  Claude Code: installed $count skills to $target_dir"
}

# ──────────────────────────────────────────────────────────────
# Kiro — uses SKILL.md with same frontmatter, different path
# ──────────────────────────────────────────────────────────────

install_kiro() {
  local target_dir="$HOME/.kiro/skills"
  mkdir -p "$target_dir"
  local count=0

  for skill_dir in "$SKILLS_DIR"/*/; do
    local skill_name
    skill_name="$(basename "$skill_dir")"
    local target="$target_dir/$skill_name"

    mkdir -p "$target"

    # Copy SKILL.md with path adjustments
    sed -e "s|~/.claude/skills|~/.kiro/skills|g" \
        -e "s|\.claude/skills|.kiro/skills|g" \
        "$skill_dir/SKILL.md" > "$target/SKILL.md"

    count=$((count + 1))
  done

  echo "  Kiro: installed $count skills to $target_dir"
}

# ──────────────────────────────────────────────────────────────
# OpenCode — uses SKILL.md format, .opencode/skills/ directory
# ──────────────────────────────────────────────────────────────

install_opencode() {
  local target_dir="./.opencode/skills"
  mkdir -p "$target_dir"
  local count=0

  for skill_dir in "$SKILLS_DIR"/*/; do
    local skill_name
    skill_name="$(basename "$skill_dir")"
    local target="$target_dir/$skill_name"

    mkdir -p "$target"

    sed -e "s|~/.claude/skills|~/.opencode/skills|g" \
        -e "s|\.claude/skills|.opencode/skills|g" \
        "$skill_dir/SKILL.md" > "$target/SKILL.md"

    count=$((count + 1))
  done

  echo "  OpenCode: installed $count skills to $target_dir"
}

# ──────────────────────────────────────────────────────────────
# Codex CLI — generates AGENTS.md (plain markdown, no frontmatter)
# ──────────────────────────────────────────────────────────────

install_codex() {
  local target_file="${1:-./AGENTS.md}"

  {
    cat <<'HEADER'
# Founder Skills Pipeline

Adversarial idea interrogation followed by structured business modeling.
Every skill writes a structured output to `./founder-outputs/`. Downstream
skills read those files. `/verdict` reads all of them and produces an
explicit BUILD / KILL / PIVOT judgment.

## Pipeline Sequence

1.  `/pressure-test` — Adversarial interrogation (run first)
2.  `/customer-archetype` — Define the specific customer
3.  `/founder-fit` — Assess founder-market fit
4.  `/scope-mode` — Calibrate ambition level
5.  `/market-size` — Bottom-up TAM/SAM/SOM
6.  `/startup-canvas` — Business model + value proposition
7.  `/unit-economics` — CAC / LTV / payback / gross margin
8.  `/regulatory-risk` — Compliance exposure (regulated industries)
9.  `/battle-cards` — Competitive intelligence
10. `/assumption-map` — Risk prioritization
11. `/pretotype` — Validation experiments
12. `/verdict` — BUILD / KILL / PIVOT judgment
13. `/build-brief` — Implementation handoff for coding agents
14. `/pitch-deck` — Investor pitch narrative
15. `/gtm-plan` — Go-to-market channel strategy

---

HEADER

    # Core pipeline skills first, then extensions, then pitch, then marketing
    local order=(
      pressure-test customer-archetype founder-fit scope-mode market-size
      startup-canvas unit-economics regulatory-risk battle-cards assumption-map pretotype verdict
      build-brief pivot-paths 10x-why-now analogous-cos
      pitch-deck investor-lens elevator-pitch objection-map
      gtm-plan oneliner cold-outreach content-strategy
      founder-pipeline
    )

    for skill_name in "${order[@]}"; do
      local skill_file="$SKILLS_DIR/$skill_name/SKILL.md"
      if [ -f "$skill_file" ]; then
        skill_to_markdown "$skill_file"
      fi
    done
  } > "$target_file"

  echo "  Codex: generated $target_file"
}

# ──────────────────────────────────────────────────────────────
# Cursor — generates .cursorrules (YAML frontmatter + markdown)
# ──────────────────────────────────────────────────────────────

install_cursor() {
  local target_file="./.cursorrules"

  {
    cat <<'HEADER'
---
description: Founder Skills Pipeline — adversarial idea interrogation and business modeling
alwaysApply: true
---

# Founder Skills Pipeline

Adversarial idea interrogation followed by structured business modeling.
Every skill writes a structured output to `./founder-outputs/`. Downstream
skills read those files. `/verdict` reads all of them and produces an
explicit BUILD / KILL / PIVOT judgment.

## Pipeline Sequence

1.  `/pressure-test` — Adversarial interrogation (run first)
2.  `/customer-archetype` — Define the specific customer
3.  `/founder-fit` — Assess founder-market fit
4.  `/scope-mode` — Calibrate ambition level
5.  `/market-size` — Bottom-up TAM/SAM/SOM
6.  `/startup-canvas` — Business model + value proposition
7.  `/unit-economics` — CAC / LTV / payback / gross margin
8.  `/regulatory-risk` — Compliance exposure (regulated industries)
9.  `/battle-cards` — Competitive intelligence
10. `/assumption-map` — Risk prioritization
11. `/pretotype` — Validation experiments
12. `/verdict` — BUILD / KILL / PIVOT judgment

---

HEADER

    local order=(
      pressure-test customer-archetype founder-fit scope-mode market-size
      startup-canvas unit-economics regulatory-risk battle-cards assumption-map pretotype verdict
      build-brief pivot-paths 10x-why-now analogous-cos
      pitch-deck investor-lens elevator-pitch objection-map
      gtm-plan oneliner cold-outreach content-strategy
      founder-pipeline
    )

    for skill_name in "${order[@]}"; do
      local skill_file="$SKILLS_DIR/$skill_name/SKILL.md"
      if [ -f "$skill_file" ]; then
        skill_to_markdown "$skill_file"
      fi
    done
  } > "$target_file"

  echo "  Cursor: generated $target_file"
}

# ──────────────────────────────────────────────────────────────
# Windsurf — generates .windsurf/rules/*.md files
# ──────────────────────────────────────────────────────────────

install_windsurf() {
  local target_dir="./.windsurf/rules"
  mkdir -p "$target_dir"

  # Pipeline overview file
  cat <<'OVERVIEW' > "$target_dir/founder-pipeline.md"
# Founder Skills Pipeline

Adversarial idea interrogation followed by structured business modeling.
Every skill writes a structured output to `./founder-outputs/`. Downstream
skills read those files. `/verdict` reads all of them and produces an
explicit BUILD / KILL / PIVOT judgment.

## Pipeline Sequence

1.  `/pressure-test` — Adversarial interrogation (run first)
2.  `/customer-archetype` — Define the specific customer
3.  `/founder-fit` — Assess founder-market fit
4.  `/scope-mode` — Calibrate ambition level
5.  `/market-size` — Bottom-up TAM/SAM/SOM
6.  `/startup-canvas` — Business model + value proposition
7.  `/unit-economics` — CAC / LTV / payback / gross margin
8.  `/regulatory-risk` — Compliance exposure (regulated industries)
9.  `/battle-cards` — Competitive intelligence
10. `/assumption-map` — Risk prioritization
11. `/pretotype` — Validation experiments
12. `/verdict` — BUILD / KILL / PIVOT judgment
OVERVIEW

  local count=1 # counting the overview file

  for skill_dir in "$SKILLS_DIR"/*/; do
    local skill_name
    skill_name="$(basename "$skill_dir")"
    local skill_file="$skill_dir/SKILL.md"

    if [ -f "$skill_file" ]; then
      strip_frontmatter "$skill_file" > "$target_dir/$skill_name.md"
      count=$((count + 1))
    fi
  done

  echo "  Windsurf: generated $count rule files in $target_dir"
}

# ──────────────────────────────────────────────────────────────
# Output directory + instruction snippets
# ──────────────────────────────────────────────────────────────

create_outputs_dir() {
  if [ ! -d "./founder-outputs" ]; then
    mkdir -p "./founder-outputs"
    echo "  Created ./founder-outputs/ directory"
  fi
}

print_post_install() {
  local platforms_str
  platforms_str=$(printf ", %s" "${INSTALLED[@]}")
  platforms_str="${platforms_str:2}" # trim leading ", "

  echo ""
  echo "────────────────────────────────────────────────────"
  echo " Installed for: $platforms_str"
  echo "────────────────────────────────────────────────────"
  echo ""
  echo "Start with: /pressure-test"
  echo ""

  if [[ " ${INSTALLED[*]} " =~ " claude " ]]; then
    echo "Add this to your project's CLAUDE.md for pipeline awareness:"
    echo ""
    cat <<'SNIPPET'
  ## Founder Skills Pipeline
  All skill outputs are saved to `./founder-outputs/`.
  Pipeline: /pressure-test → /customer-archetype → /founder-fit →
  /scope-mode → /market-size → /startup-canvas → /unit-economics →
  /regulatory-risk → /battle-cards → /assumption-map →
  /pretotype → /verdict → /build-brief
SNIPPET
    echo ""
  fi
}

# ──────────────────────────────────────────────────────────────
# Usage
# ──────────────────────────────────────────────────────────────

usage() {
  cat <<'USAGE'
Usage: ./setup [OPTIONS]
       npx founder-skills [OPTIONS]

Install founder-skills for your coding agent(s).

Options:
  --auto              Auto-detect installed agents and install for all
  --claude [scope]    Install for Claude Code (scope: global or local, default: global)
  --codex             Generate AGENTS.md for Codex CLI
  --cursor            Generate .cursorrules for Cursor
  --kiro              Install SKILL.md files for Kiro
  --opencode          Install SKILL.md files for OpenCode
  --windsurf          Generate .windsurf/rules/ for Windsurf
  --all               Install for all supported platforms
  -h, --help          Show this help

If no flags are given, auto-detects installed agents and prompts to confirm.
When run via npx, defaults to --auto (no prompt).

Examples:
  npx founder-skills              # auto-detect and install (npx, no prompt)
  npx founder-skills --claude     # Claude Code global install via npx
  npx founder-skills --all        # install for every supported platform via npx
  ./setup --auto                  # detect and install for all found agents
  ./setup --claude global         # Claude Code global install
  ./setup --claude local          # Claude Code project-local install
  ./setup --codex --cursor        # generate for both Codex and Cursor
  ./setup --all                   # install for every supported platform
USAGE
}

# ──────────────────────────────────────────────────────────────
# Main
# ──────────────────────────────────────────────────────────────

INSTALLED=()

run_install() {
  echo ""
  echo "Installing founder-skills..."
  echo ""

  for platform in "$@"; do
    case "$platform" in
      claude-global)
        install_claude "global"
        INSTALLED+=("claude")
        ;;
      claude-local)
        install_claude "local"
        INSTALLED+=("claude")
        ;;
      codex)
        install_codex "./AGENTS.md"
        INSTALLED+=("codex")
        ;;
      cursor)
        install_cursor
        INSTALLED+=("cursor")
        ;;
      kiro)
        install_kiro
        INSTALLED+=("kiro")
        ;;
      opencode)
        install_opencode
        INSTALLED+=("opencode")
        ;;
      windsurf)
        install_windsurf
        INSTALLED+=("windsurf")
        ;;
    esac
  done

  create_outputs_dir
  print_post_install
}

# Parse arguments
if [ $# -eq 0 ]; then
  # When run via npx, skip the prompt and go straight to auto-detect
  if [ "$NPX_MODE" = "true" ]; then
    detect_platforms
    if [ ${#PLATFORMS[@]} -eq 0 ]; then
      echo "No coding agents detected on PATH."
      echo "Run with --all to install for every supported platform, or --help for options."
      exit 1
    fi
    targets=()
    for p in "${PLATFORMS[@]}"; do
      [ "$p" = "claude" ] && targets+=("claude-global") || targets+=("$p")
    done
    run_install "${targets[@]}"
    exit 0
  fi

  # Interactive mode
  detect_platforms

  if [ ${#PLATFORMS[@]} -gt 0 ]; then
    echo "Detected coding agents: ${PLATFORMS[*]}"
    echo ""
    read -rp "Install for all detected agents? [Y/n]: " yn
    case "${yn:-Y}" in
      [Yy]*)
        targets=()
        for p in "${PLATFORMS[@]}"; do
          if [ "$p" = "claude" ]; then
            targets+=("claude-global")
          else
            targets+=("$p")
          fi
        done
        run_install "${targets[@]}"
        ;;
      *)
        echo ""
        echo "Available platforms:"
        echo "  1) Claude Code (global)"
        echo "  2) Claude Code (project-local)"
        echo "  3) Codex CLI (AGENTS.md)"
        echo "  4) Cursor (.cursorrules)"
        echo "  5) Kiro"
        echo "  6) OpenCode"
        echo "  7) Windsurf"
        echo ""
        read -rp "Choose (comma-separated, e.g. 1,3): " choices
        targets=()
        IFS=',' read -ra nums <<< "$choices"
        for num in "${nums[@]}"; do
          num=$(echo "$num" | tr -d ' ')
          case "$num" in
            1) targets+=("claude-global") ;;
            2) targets+=("claude-local") ;;
            3) targets+=("codex") ;;
            4) targets+=("cursor") ;;
            5) targets+=("kiro") ;;
            6) targets+=("opencode") ;;
            7) targets+=("windsurf") ;;
          esac
        done
        if [ ${#targets[@]} -eq 0 ]; then
          echo "No platforms selected. Exiting."
          exit 1
        fi
        run_install "${targets[@]}"
        ;;
    esac
  else
    echo "No coding agents detected on PATH."
    echo ""
    echo "Available platforms:"
    echo "  1) Claude Code (global)"
    echo "  2) Claude Code (project-local)"
    echo "  3) Codex CLI (AGENTS.md)"
    echo "  4) Cursor (.cursorrules)"
    echo "  5) Kiro"
    echo "  6) OpenCode"
    echo "  7) Windsurf"
    echo ""
    read -rp "Choose (comma-separated, e.g. 1,3): " choices
    targets=()
    IFS=',' read -ra nums <<< "$choices"
    for num in "${nums[@]}"; do
      num=$(echo "$num" | tr -d ' ')
      case "$num" in
        1) targets+=("claude-global") ;;
        2) targets+=("claude-local") ;;
        3) targets+=("codex") ;;
        4) targets+=("cursor") ;;
        5) targets+=("kiro") ;;
        6) targets+=("opencode") ;;
        7) targets+=("windsurf") ;;
      esac
    done
    if [ ${#targets[@]} -eq 0 ]; then
      echo "No platforms selected. Exiting."
      exit 1
    fi
    run_install "${targets[@]}"
  fi
else
  targets=()
  claude_scope="global"

  while [ $# -gt 0 ]; do
    case "$1" in
      --auto)
        detect_platforms
        for p in "${PLATFORMS[@]}"; do
          if [ "$p" = "claude" ]; then
            targets+=("claude-global")
          else
            targets+=("$p")
          fi
        done
        shift
        ;;
      --claude)
        if [ $# -gt 1 ] && [[ "$2" =~ ^(global|local)$ ]]; then
          claude_scope="$2"
          shift
        fi
        targets+=("claude-$claude_scope")
        shift
        ;;
      --codex)    targets+=("codex"); shift ;;
      --cursor)   targets+=("cursor"); shift ;;
      --kiro)     targets+=("kiro"); shift ;;
      --opencode) targets+=("opencode"); shift ;;
      --windsurf) targets+=("windsurf"); shift ;;
      --all)
        targets=("claude-global" "codex" "cursor" "kiro" "opencode" "windsurf")
        shift
        ;;
      -h|--help)
        usage
        exit 0
        ;;
      *)
        echo "Unknown option: $1"
        usage
        exit 1
        ;;
    esac
  done

  if [ ${#targets[@]} -eq 0 ]; then
    echo "No platforms specified."
    usage
    exit 1
  fi

  run_install "${targets[@]}"
fi
